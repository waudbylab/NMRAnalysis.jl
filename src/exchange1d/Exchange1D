function __init__()
    # Register analysis rule for R1rho and CEST experiments
    rule = MultiFileRule(expts -> begin
                             oneD = filter(e -> "1d" in e.types, expts)
                             matched = filter(e -> ("r1rho" in e.types || "cest" in e.types),
                                              oneD)
                             matched2 = filter(e -> ("relaxation" in e.types &&
                                                     "R1" in e.features), oneD)
                             combined = vcat(matched, matched2)
                             length(combined) > 0 ? combined : nothing
                         end,
                         expts -> exchange1d([e.filename for e in expts]),
                         "Exchange analysis (R1ρ and CEST)")
    return register_analysis!(rule)
end

